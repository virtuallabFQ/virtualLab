[node name="description" type="Label" parent="AL5" unique_id=2014429573]
layout_mode = 1
anchors_preset = -1
anchor_left = 0.047000002
anchor_top = 0.064
anchor_right = 0.98200005
anchor_bottom = 0.933
offset_left = 0.41999817
offset_top = 0.00799942
offset_right = -31.480103
offset_bottom = 0.10095215
theme_override_fonts/font = ExtResource("4_ey48s")
theme_override_font_sizes/font_size = 32
text = "

    Meça a massa de soluto necessária para um gobelé com 
auxílio de uma espátula, usando uma balança digital;
     Dissolva todo o soluto usando água destilada e agitando 
com uma vareta de vidro;
     Verta a solução para o balão volumétrico com o auxílio 
de um funil e de uma vareta de vidro, lavando os materiais 
com solvente;
     Adicione água destilada até à marca, primeiro com o 
esguicho e depois com um conta-gotas;
    Tape e homogeneíze a solução, invertendo várias vezes 
o balão volumétrico.
"

