theme_override_fonts/font = ExtResource("4_ey48s")
theme_override_font_sizes/font_size = 32
text = "

   Coloque um gobelé seco no prato da balança e registe a 
massa do gobelé;
     Encha, com o esguicho, uma bureta com água e acerte-a 
no zero;
    Verta água gota a gota, da bureta para o gobelé, contando 
100 gotas;
    Registe a medida do volume escoado, isto é, o volume das 
100 gotas de água;
     Coloque o gobelé com água no prato da balança e registe 
o valor medido para a massa de 100 gotas de água."

